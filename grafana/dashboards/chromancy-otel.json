      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (device) (wled_requests_total)",
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "WLED HTTP Requests by Device",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
