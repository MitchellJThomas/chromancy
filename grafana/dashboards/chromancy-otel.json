      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (wled_request_duration_seconds_bucket))",
