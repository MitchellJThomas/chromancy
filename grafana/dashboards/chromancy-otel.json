              {
                "color": "blue",
                "value": 0
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
