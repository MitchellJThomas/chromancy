{
    "name": "Chromancy",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "remoteUser": "nonroot",
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "fish",
                "terminal.integrated.profiles.linux": {
                    "fish": {
                        "path": "/bin/fish"
                    }
                }
            }
        }
    }
}
